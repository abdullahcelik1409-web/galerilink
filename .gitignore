# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (CRITICAL: never commit secrets)
.env
.env.*
.env.local
.env.development
.env.production
.env.staging

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# agent / workspace tools (not project code)
.agent/
.gemini/
.antigravityignore

# supabase local
supabase/.temp/
